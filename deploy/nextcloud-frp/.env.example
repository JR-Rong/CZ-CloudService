# Copy this file to .env and replace every change-me value before first start.
# Do not commit the real .env file.

# Host-side runtime data. Relative paths are resolved from deploy/nextcloud-frp.
NEXTCLOUD_ROOT=./data

# Nextcloud public access through frp.
NEXTCLOUD_TRUSTED_DOMAINS="60.205.213.254 60.205.213.254:2233 localhost 127.0.0.1"
OVERWRITEHOST=60.205.213.254:2233
OVERWRITEPROTOCOL=http
OVERWRITECLIURL=http://60.205.213.254:2233

# Local debugging port on the storage machine. frpc talks to nextcloud:80 inside Docker.
NEXTCLOUD_LOCAL_BIND=127.0.0.1
NEXTCLOUD_LOCAL_PORT=8080

# Initial admin account. Only used during the first Nextcloud installation.
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-me-admin-password

# MariaDB credentials. Use long random values in production.
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=change-me-db-password
MYSQL_ROOT_PASSWORD=change-me-db-root-password

# Upload limits. APACHE_BODY_LIMIT=0 means Apache will not enforce its own body cap.
PHP_MEMORY_LIMIT=1024M
PHP_UPLOAD_LIMIT=2048M
APACHE_BODY_LIMIT=0

# Keep this pointing at frpc.toml.example for dry-run validation.
# For real deployment, copy frpc.toml.example to frpc.toml and set this to ./frpc.toml.
FRPC_CONFIG_FILE=./frpc.toml.example

# Backup defaults used by scripts/unix/backup-nextcloud.sh.
BACKUP_RETENTION_DAYS=14
